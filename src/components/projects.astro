---
import InfiniteMenu from './InfiniteMenu.jsx';

export const myProjects = [
  {
    slug: "application-gps",
    title: "Application de GPS",
    description: "Développement d'une application robuste en C++ permettant la gestion complète d'un catalogue de livres, des adhérents et des emprunts. Focus majeur sur la programmation orientée objet et l'encapsulation.",
    tags: ["C++", "POO", "Algorithmique"],
    githubUrl: "#",
    image: "https://picsum.photos/id/10/600/600?grayscale",
    link: "/projets/application-gps"
  },
  {
    slug: "messagerie-instantanee",
    title: "Application de messagerie instantanée",
    description: "Création d'un outil d'analyse comparative mesurant la complexité empirique de différents algorithmes (Tri à bulles, Rapide, Insertion) en fonction de la taille des structures.",
    tags: ["C / C++", "Algorithmique", "Optimisation"],
    githubUrl: "#",
    image: "https://picsum.photos/id/48/600/600?grayscale",
    link: "/projets/messagerie-instantanee"
  },
  {
    slug: "netflix-likes",
    title: "Application Netflix Likes",
    description: "Création d'un outil d'analyse comparative mesurant la complexité empirique de différents algorithmes (Tri à bulles, Rapide, Insertion) en fonction de la taille des structures.",
    tags: ["C / C++", "Algorithmique", "Optimisation"],
    githubUrl: "#",
    image: "https://picsum.photos/id/60/600/600?grayscale",
    link: "/projets/netflix-likes"
  },
  {
    slug: "homelab",
    title: "Serveur Domestique Homelab",
    description: "Architecture et administration d'un serveur personnel sur Raspberry Pi. Configuration de services conteneurisés avec Docker et mise en place d'une instance Umami Analytics auto-hébergée.",
    tags: ["Linux", "Docker", "Raspberry Pi"],
    image: "https://picsum.photos/id/160/600/600?grayscale",
    link: "/projets/homelab"
  }
];
---

<section id="projects" class="py-24 bg-zinc-950 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- En-tête de section style minimaliste -->
    <div class="mb-12">
      <span class="text-xs font-bold tracking-widest uppercase text-purple-500">Portfolio</span>
      <h2 class="text-4xl font-black text-white mt-1">Projets Récents</h2>
      <div class="h-1 w-12 bg-purple-600 mt-3 rounded-full"></div>
    </div>

    <!-- Conteneur parent du Canvas 3D (Hauteur fixe requise par WebGL) -->
    <div class="w-full h-[600px] relative border border-white/5 bg-zinc-900/20 rounded-3xl overflow-hidden backdrop-blur-md">
      <InfiniteMenu items={myProjects} scale={0.85} client:load />
    </div>

  </div>
</section>