---
export const myProjects = [
  {
    slug: "application-gps",
    title: "Application de GPS",
    description: "Développement d'une application robuste en C++ permettant la gestion complète d'un catalogue de livres, des adhérents et des emprunts. Focus majeur sur la programmation orientée objet.",
    status: "Terminé",
    tags: ["C++", "POO", "Algorithmique"],
    githubUrl: "https://github.com",
    image: "https://picsum.photos/id/10/800/600?grayscale",
    link: "/projets/application-gps"
  },
  {
    slug: "messagerie-instantanee",
    title: "Messagerie Instantanée",
    description: "Création d'un outil d'analyse comparative mesurant la complexité empirique de différents algorithmes (Tri à bulles, Rapide, Insertion) en fonction de la taille des structures.",
    status: "En développement",
    tags: ["C / C++", "Algorithmique", "Optimisation"],
    githubUrl: "https://github.com",
    image: "https://picsum.photos/id/48/800/600?grayscale",
    link: "/projets/messagerie-instantanee"
  },
  {
    slug: "netflix-likes",
    title: "Application Netflix Likes",
    description: "Plateforme de recommandation de contenus vidéo développée avec une architecture orientée composants et gestion d'état dynamique.",
    status: "Terminé",
    tags: ["React", "Tailwind", "Node.js"],
    githubUrl: "https://github.com",
    image: "https://picsum.photos/id/60/800/600?grayscale",
    link: "/projets/netflix-likes"
  },
  {
    slug: "homelab",
    title: "Serveur Domestique Homelab",
    description: "Architecture et administration d'un serveur personnel sur Raspberry Pi. Configuration de services conteneurisés avec Docker et instance Umami Analytics.",
    status: "Opérationnel",
    tags: ["Linux", "Docker", "Raspberry Pi"],
    githubUrl: "https://github.com",
    image: "https://picsum.photos/id/160/800/600?grayscale",
    link: "/projets/homelab"
  }
];
---

<section id="projects" class="py-20 bg-zinc-950 relative overflow-hidden text-white border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    
    <!-- En-tête de section -->
    <div class="mb-12">
      <span class="text-xs font-bold tracking-widest uppercase text-purple-400 bg-purple-500/10 px-3 py-1 rounded-full border border-purple-500/20">
        Portfolio
      </span>
      <h2 class="text-4xl md:text-5xl font-black mt-3">Projets Récents</h2>
      <p class="text-zinc-400 mt-2">Découvrez une sélection de mes réalisations logicielles et systèmes.</p>
    </div>

    <!-- Grille 2 colonnes -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {myProjects.map((project) => (
        <div class="group flex flex-col justify-between bg-zinc-900/40 border border-white/5 rounded-2xl p-4 hover:border-purple-500/30 transition-all duration-300 hover:shadow-2xl hover:shadow-purple-500/5">
          
          <!-- Image cliquable -->
          <div>
            <a href={project.link} class="block overflow-hidden rounded-xl mb-4 relative aspect-video">
              <img 
                src={project.image} 
                alt={project.title} 
                loading="lazy" 
                decoding="async" 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 via-transparent to-transparent opacity-60 group-hover:opacity-30 transition-opacity"></div>
            </a>

            <!-- Contenu -->
            <div class="px-2">
              <div class="flex items-center justify-between gap-2 mb-1">
                <h3 class="text-xl font-bold text-white group-hover:text-purple-300 transition-colors">
                  <a href={project.link}>{project.title}</a>
                </h3>
                <span class="text-xs px-2.5 py-0.5 rounded-full bg-zinc-800 text-zinc-300 font-medium border border-white/5 whitespace-nowrap">
                  {project.status}
                </span>
              </div>
              
              <p class="text-sm text-zinc-400 line-clamp-2 mt-2 leading-relaxed">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mt-4">
                {project.tags.map(tag => (
                  <span class="text-[11px] px-2.5 py-1 rounded-md bg-purple-500/10 text-purple-300 font-mono border border-purple-500/20">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Actions / Liens -->
          <div class="flex items-center justify-between pt-6 mt-4 border-t border-white/5 px-2">
            <a 
              href={project.link} 
              class="text-sm font-semibold text-purple-400 hover:text-purple-300 flex items-center gap-1 group/link"
            >
              En savoir plus 
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 transition-transform group-hover/link:translate-x-1">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>

            <div class="flex gap-2">
              {project.githubUrl && (
                <a 
                  href={project.githubUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  aria-label="Code source GitHub"
                  class="p-2.5 rounded-xl bg-zinc-800/80 hover:bg-purple-600 text-zinc-300 hover:text-white transition-all duration-300 border border-white/10"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                    <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.501 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"></path>
                  </svg>
                </a>
              )}
              
              <a 
                href={project.link} 
                aria-label="Voir le projet"
                class="p-2.5 rounded-xl bg-purple-600/20 hover:bg-purple-600 text-purple-300 hover:text-white transition-all duration-300 border border-purple-500/30"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Bouton GitHub global -->
    <div class="mt-14 text-center">
      <a 
        href="https://github.com/yvlovertex" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="inline-flex items-center gap-3 px-8 py-3.5 rounded-full bg-zinc-900 hover:bg-zinc-800 text-zinc-200 font-medium transition-all duration-300 border border-white/10 hover:border-purple-500/40 hover:scale-105 shadow-xl"
      >
        <span>Plus de projets sur GitHub</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-purple-400">
          <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.501 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"></path>
        </svg>
      </a>
    </div>

  </div>
</section>