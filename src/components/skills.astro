---
const skillCategories = [
  {
    title: "Développement & POO",
    skills: ["C / C++", "Java", "JavaScript", "HTML5 / CSS3", "Tailwind CSS"]
  },
  {
    title: "Architecture & Données",
    skills: ["SQL (PostgreSQL / Oracle)", "Conception BD (Merise)", "Algorithmique", "Structures de données"]
  },
  {
    title: "Systèmes & Outils",
    skills: ["Linux / Bash", "Docker & Conteneurs", "Administration Homelab", "Git / GitHub", "SSH & Réseaux"]
  }
];

// Liste de tes Soft Skills
const softSkills = [
  "Autonomie & Rigueur",
  "Esprit d'équipe",
  "Résolution de problèmes",
  "Adaptabilité",
  "Curiosité technique",
  "Gestion du temps",
  "Communication"
];
---

<section id="skills" class="py-20 bg-zinc-950 border-t border-white/5 relative overflow-hidden text-white">
  <!-- Halos lumineux en arrière-plan -->
  <div class="absolute top-1/2 left-10 -translate-y-1/2 -z-10 w-96 h-96 bg-purple-600/5 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6">
    
    <!-- En-tête de section -->
    <div class="mb-12">
      <span class="text-xs font-bold tracking-widest uppercase text-purple-400 bg-purple-500/10 px-3 py-1 rounded-full border border-purple-500/20">
        Boîte à outils
      </span>
      <h2 class="text-4xl md:text-5xl font-black mt-3">Mes Compétences</h2>
      <p class="text-zinc-400 mt-2">Technologies, langages et savoir-être que j'utilise au quotidien.</p>
    </div>

    <!-- 1. Les 3 cartes de compétences techniques -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      {skillCategories.map((category) => (
        <div class="bg-zinc-900/40 border border-white/5 rounded-2xl p-6 backdrop-blur-sm hover:border-purple-500/30 transition-all duration-300 flex flex-col justify-between">
          <div>
            <h3 class="text-xl font-bold text-white mb-6 pb-3 border-b border-white/10 flex items-center justify-between">
              <span>{category.title}</span>
              <span class="w-2 h-2 rounded-full bg-purple-500 shadow-[0_0_8px_rgba(168,85,247,0.8)]"></span>
            </h3>
            
            <ul class="space-y-3.5">
              {category.skills.map((skill) => (
                <li class="flex items-center gap-3 group cursor-default">
                  <span class="w-1.5 h-1.5 rounded-full bg-zinc-600 group-hover:bg-purple-400 group-hover:scale-125 transition-all duration-300"></span>
                  <span class="text-zinc-300 text-sm group-hover:text-white transition-colors">
                    {skill}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- 2. Défilement vertical géant pour les Soft Skills -->
    <div class="pt-8 border-t border-white/5">
      <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-500 text-center mb-10">
        Soft Skills
      </h3>

      <!-- Fenêtre de visionnage avec masque de dégradé haut/bas -->
      <div class="relative h-[280px] w-full overflow-hidden [mask-image:linear-gradient(to_bottom,transparent_0%,black_25%,black_75%,transparent_100%)]">
        
        <!-- Conteneur animé -->
        <div class="vertical-marquee-track flex flex-col items-center w-full">
          
          <!-- Premier jeu de texte -->
          <div class="flex flex-col items-center space-y-6 pb-6 w-full">
            {softSkills.map((skill) => (
              <div class="text-3xl md:text-5xl font-black text-zinc-400 hover:text-white transition-colors cursor-default text-center tracking-tight py-1">
                {skill}
              </div>
            ))}
          </div>

          <!-- Doublon exact pour créer la boucle infinie sans interruption -->
          <div class="flex flex-col items-center space-y-6 pb-6 w-full" aria-hidden="true">
            {softSkills.map((skill) => (
              <div class="text-3xl md:text-5xl font-black text-zinc-400 hover:text-white transition-colors cursor-default text-center tracking-tight py-1">
                {skill}
              </div>
            ))}
          </div>

        </div>

      </div>
    </div>

  </div>
</section>

<style>
  @keyframes scrollUp {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  .vertical-marquee-track {
    will-change: transform;
    animation: scrollUp 14s linear infinite;
  }

</style>