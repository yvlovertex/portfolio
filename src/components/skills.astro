---
// On organise tes compétences par catégories
const skillCategories = [
  {
    title: "Développement",
    skills: ["C / C++", "Java", "JavaScript", "HTML5 / CSS3", "Tailwind CSS"]
  },
  {
    title: "Architecture & Données",
    skills: ["SQL (PostgreSQL / Oracle)", "Conception BD (Merise)", "Algorithmique", "Structures de données"]
  },
  {
    title: "Systèmes & Outils",
    skills: ["Linux / Bash", "Docker & Conteneurs", "Administration Homelab", "Git / GitHub", "SSH & Réseaux"]
  }
];
---

<section id="skills" class="py-24 bg-brand-card/20 border-y border-white/5 relative overflow-hidden">
  <div class="absolute top-1/4 left-10 -z-10 w-72 h-72 bg-brand-blue/5 blur-[100px] rounded-full"></div>

  <div class="max-w-5xl mx-auto px-6">
    
    <div class="space-y-2 mb-16">
      <span class="text-xs font-semibold tracking-widest uppercase text-brand-blue">Boîte à outils</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-brand-text">Mes Compétences</h2>
      <br>
      <div class="h-1 w-12 bg-gradient-to-r from-brand-blue to-brand-purple rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {skillCategories.map((category) => (
        <div class="bg-brand-card/40 border border-white/5 rounded-2xl p-6 backdrop-blur-sm hover:border-brand-blue/20 transition-all duration-300">
          <h3 class="text-lg font-bold text-brand-blue mb-6 pb-2 border-b border-white/5">
            {category.title}
          </h3>
          
          <ul class="space-y-3.5">
            {category.skills.map((skill) => (
              <li class="flex items-center gap-3 group">
                <span class="w-1.5 h-1.5 rounded-full bg-brand-purple shadow-[0_0_8px_rgba(124,58,237,0.8)] group-hover:bg-brand-blue group-hover:shadow-[0_0_8px_rgba(59,130,246,0.8)] transition-all duration-300"></span>
                <span class="text-brand-text/80 text-md group-hover:text-brand-text transition-colors">
                  {skill}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>