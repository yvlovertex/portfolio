---
interface Props {
  title: string;
  description: string;
  tags: string[];
  githubUrl?: string;
}

const { title, description, tags, githubUrl } = Astro.props;
---

<div class="bg-brand-card/40 border border-white/5 rounded-2xl p-6 backdrop-blur-sm hover:border-brand-purple/30 hover:shadow-[0_0_30px_rgba(124,58,237,0.1)] transition-all duration-300 flex flex-col justify-between h-full group">
  <div class="space-y-4">
    <!-- En-tête de la carte -->
    <div class="flex justify-between items-start">
      <h3 class="text-xl font-bold text-brand-text group-hover:text-brand-purple transition-colors duration-300">
        {title}
      </h3>
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-brand-text/50 hover:text-brand-blue transition-colors" title="Voir sur GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" h="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
      )}
    </div>

    <!-- Description -->
    <p class="text-brand-text/70 text-sm leading-relaxed">
      {description}
    </p>
  </div>

  <!-- Badges / Technologies -->
  <div class="flex flex-wrap gap-2 pt-6">
    {tags.map((tag) => (
      <span class="text-xs font-medium px-2.5 py-1 rounded-md bg-white/5 border border-white/5 text-brand-text/60">
        {tag}
      </span>
    ))}
  </div>
</div>