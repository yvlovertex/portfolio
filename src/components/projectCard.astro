---
interface Props {
  title: string;
  description: string;
  tags: string[];
  image: string;
  link: string;
}

const { title, description, tags, image, link } = Astro.props;
---

<div class="group relative bg-brand-card/20 border border-white/10 rounded-2xl overflow-hidden backdrop-blur-sm transition-all duration-300 hover:border-brand-purple/50 hover:shadow-[0_0_30px_rgba(166,200,255,0.1)] flex flex-col h-full">
  <!-- Image de couverture -->
  <div class="relative aspect-video w-full overflow-hidden bg-zinc-800">
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover grayscale contrast-125 transition-all duration-500 group-hover:scale-105 group-hover:grayscale-0"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-brand-bg via-transparent to-transparent opacity-60"></div>
  </div>

  <!-- Contenu textuel -->
  <div class="p-6 flex flex-col flex-grow justify-between space-y-4">
    <div class="space-y-2">
      <h3 class="text-xl font-bold text-white group-hover:text-brand-purple transition-colors duration-300">
        {title}
      </h3>
      <p class="text-sm text-brand-text/70 line-clamp-3 leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Tags & Bouton -->
    <div class="space-y-4 pt-2">
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="text-xs px-2.5 py-1 rounded-md bg-white/5 border border-white/5 text-brand-text/80">
            {tag}
          </span>
        ))}
      </div>
      
      <a 
        href={link} 
        class="inline-flex items-center text-sm font-semibold text-brand-purple group-hover:text-white transition-colors duration-300 gap-1"
      >
        Voir le projet 
        <span class="transform transition-transform duration-300 group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</div>