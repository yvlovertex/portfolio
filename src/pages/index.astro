---
import Layout from "../layouts/layout.astro";
import About from "../components/about.astro";
import Skills from "../components/skills.astro";
import Formation from "../components/formation.astro";
import Project from "../components/projects.astro";

import Lightfall from "../components/Lightfall.jsx";
import SplitText from "../components/SplitText.jsx";
import HeroDescription from "../components/HeroDescription.jsx";
import HeroButtons from '../components/HeroButtons.jsx';
import TechMarquee from '../components/TechMarquee.astro';
---

<Layout title="KLEIN Julyan - Portfolio">
    <!-- Navbar Flottante -->
    <header class="fixed top-0 left-0 right-0 z-50 flex justify-center p-4 transition-all duration-500 ease-in-out">
        <div 
            id="navbar"
            class="nav-default flex items-center justify-between transition-all duration-500 ease-in-out"
        >
            <!-- Logo / Brand -->
            <a href="/" class="flex items-center gap-2 group">
                <span class="text-xl font-black tracking-wider bg-gradient-to-r from-purple-400 via-purple-300 to-indigo-400 bg-clip-text text-transparent group-hover:opacity-80 transition-opacity">
                    PORTFOLIO
                </span>
            </a>

            <!-- Liens de Navigation -->
            <nav class="hidden md:flex items-center space-x-8 text-sm font-medium text-zinc-300">
                <a href="#hero" class="hover:text-white transition-colors">Accueil</a>
                <a href="#about" class="hover:text-white transition-colors">À propos</a>
                <a href="#formation" class="hover:text-white transition-colors">Formation</a>
                <a href="#skills" class="hover:text-white transition-colors">Compétences</a>
                <a href="#projects" class="hover:text-white transition-colors">Projets</a>
            </nav>

            <!-- Bouton d'action -->
            <div class="flex items-center gap-3">
                <a
                    href="/chat"
                    class="px-5 py-2.5 rounded-full text-xs font-semibold bg-purple-500/10 text-purple-300 border border-purple-500/30 hover:bg-purple-600 hover:text-white hover:border-transparent transition-all duration-300 shadow-lg shadow-purple-500/10"
                >
                    🤖 Chat IA
                </a>
            </div>
        </div>
    </header>

    <main id="hero" class="relative min-h-screen flex flex-col justify-center items-center px-6 overflow-hidden">
        <Lightfall
            client:load
            colors={["#A6C8FF", "#5227FF", "#FF9FFC"]}
            backgroundColor="#0E0E17"
            speed={0.4}
            streakCount={6}
            streakWidth={1.2}
            streakLength={1.5}
            glow={1.2}
            density={0.5}
            twinkle={1}
            zoom={2.5}
            backgroundGlow={0.4}
            opacity={1}
            mouseInteraction={false}
            mouseStrength={1.2}
            mouseRadius={0.7}
        />

        <div class="text-center max-w-3xl space-y-8 z-10 pt-28">
            <div class="block py-2">
                <SplitText
                    client:load
                    text="JULYAN KLEIN"
                    tag="h1"
                    className="text-5xl md:text-8xl font-black tracking-tighter uppercase text-white drop-shadow-[0_5px_5px_rgba(0,0,0,0.8)]"
                    delay={40}
                    duration={0.6}
                    ease="power4.out"
                    from={{ opacity: 0, y: 30 }}
                    to={{ opacity: 1, y: 0 }}
                />
            </div>

            <HeroDescription client:load />

            <HeroButtons client:load />

            <br>

            <TechMarquee client:load />
        </div>
    </main>

    <About />
    <Formation />
    <Skills />
    <Project />

    <footer class="py-8 border-t border-white/5 text-center text-sm text-zinc-500">
        <p>© 2026 Julyan KLEIN. Propulsé par Astro & Tailwind CSS.</p>
    </footer>
</Layout>

<!-- Script pour basculer les classes au scroll -->
<script>
    const navbar = document.getElementById('navbar');

    const handleScroll = () => {
        if (window.scrollY > 40) {
            navbar?.classList.add('nav-scrolled');
            navbar?.classList.remove('nav-default');
        } else {
            navbar?.classList.add('nav-default');
            navbar?.classList.remove('nav-scrolled');
        }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
</script>

<style is:global>
    /* Style par défaut (Haut de page / Large & Épuré) */
    .nav-default {
        width: 86%;
        max-width: 100%;
        padding: 0px 0px;
        background-color: transparent;
        border-radius: 0px;
        border: 1px solid transparent;
        box-shadow: none;
        backdrop-filter: blur(0px);
    }

    /* Style au scroll (Capsule flottante) */
    .nav-scrolled {
        width: 100%;
        max-width: 48rem; /* Equivalent max-w-3xl */
        padding: 10px 24px;
        background-color: rgba(9, 9, 11, 0.8);
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 2px 8px 0 rgba(0, 0, 0, 0.4), inset 0 1px 0 0 rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(16px);
    }

    @keyframes gradientShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    @keyframes scroll {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
    }

    .animate-scroll {
        animation: scroll 35s linear infinite;
    }

    .animate-scroll:hover {
        animation-play-state: paused;
    }
</style>