---
import Layout from '../layouts/layout.astro';
---

<Layout title="404 - Page non trouvée">
  <main class="min-h-[80vh] flex flex-col items-center justify-center text-center px-6 py-24">
    
    <!-- Code d'erreur -->
    <h1 class="text-9xl font-black text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-indigo-500 select-none">
      404
    </h1>

    <!-- Message d'explication -->
    <h2 class="text-3xl font-bold text-white mt-4">
      Oups ! Vous semblez perdu dans l'espace.
    </h2>
    
    <p class="text-zinc-400 mt-2 max-w-md">
      La page que vous recherchez n'existe pas ou a été déplacée. Vous allez être redirigé automatiquement dans <span id="timer" class="text-purple-400 font-bold">10</span> secondes.
    </p>

    <!-- Boutons -->
    <div class="mt-8 flex flex-wrap gap-4 justify-center">
      <a 
        href="/" 
        class="px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-medium rounded-xl transition-all duration-300 shadow-lg shadow-purple-500/20"
      >
        Retourner à l'accueil
      </a>
      
      <button 
        onclick="history.back()" 
        class="px-6 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-medium rounded-xl transition-all duration-300 border border-white/10"
      >
        Page précédente
      </button>
    </div>

  </main>
</Layout>

<!-- Script de redirection automatique -->
<script>
  let seconds = 10;
  const timerElement = document.getElementById('timer');

  const interval = setInterval(() => {
    seconds--;
    if (timerElement) timerElement.textContent = seconds.toString();

    if (seconds <= 0) {
      clearInterval(interval);
      window.location.href = '/';
    }
  }, 1000);
</script>