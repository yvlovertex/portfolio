---
import Layout from "../../layouts/layout.astro";
---

<Layout title="Serveur Homelab - Julyan KLEIN">
  <header class="fixed top-0 left-0 right-0 z-50 flex justify-center p-4 md:p-6">
    <div class="w-full max-w-5xl flex items-center justify-between px-6 py-3 rounded-full bg-zinc-950/60 backdrop-blur-xl border border-white/10 shadow-2xl">
      <a href="/#projects" class="flex items-center gap-2 text-zinc-300 hover:text-white transition-colors text-sm font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        <span>Retour aux projets</span>
      </a>
      <span class="text-sm font-bold bg-gradient-to-r from-purple-400 to-indigo-400 bg-clip-text text-transparent">KLEIN.</span>
    </div>
  </header>

  <main class="min-h-screen bg-zinc-950 text-white pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto space-y-10">
      <div>
        <span class="text-xs font-bold tracking-widest uppercase text-purple-400 bg-purple-500/10 px-3 py-1 rounded-full border border-purple-500/20">Opérationnel</span>
        <h1 class="text-4xl md:text-6xl font-black mt-4">Serveur Domestique Homelab</h1>
      </div>

      <div class="aspect-video w-full rounded-2xl overflow-hidden border border-white/10 bg-zinc-900">
        <img src="https://picsum.photos/id/160/1200/675?grayscale" alt="Serveur Homelab" class="w-full h-full object-cover" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pt-6 border-t border-white/10">
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase text-zinc-500">Technologies</h3>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2.5 py-1 rounded bg-purple-500/10 text-purple-300 border border-purple-500/20">Linux</span>
            <span class="text-xs px-2.5 py-1 rounded bg-purple-500/10 text-purple-300 border border-purple-500/20">Docker</span>
            <span class="text-xs px-2.5 py-1 rounded bg-purple-500/10 text-purple-300 border border-purple-500/20">Raspberry Pi</span>
          </div>
        </div>

        <div class="md:col-span-2 space-y-4 text-zinc-300">
          <h2 class="text-2xl font-bold text-white">À propos du projet</h2>
          <p>
            Architecture et administration d'un serveur personnel sur Raspberry Pi. Configuration de services conteneurisés avec Docker et mise en place d'une instance Umami Analytics auto-hébergée.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>